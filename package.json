{
  "name": "windtribe",
  "version": "0.0.0",
  "private": true,
  "description": "WindTribe monorepo — guest site, centre admin, hotel admin, and shared packages.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:guest": "pnpm --filter guest-site dev",
    "dev:centre": "pnpm --filter centre-admin dev",
    "dev:hotel": "pnpm --filter hotel-admin dev",
    "build": "pnpm -r --parallel build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@playwright/test": "^1.59.1",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "supabase": "^2.92.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "supabase",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# WindTribe / Syndeo — local environment template
# ─────────────────────────────────────────────────────────────────────────────
#
# USAGE:
#   1. Save this file as `.env.local` (or `.env`) in your project root.
#   2. Fill in real values next to each variable below.
#   3. Ensure `.env.local` is listed in `.gitignore` (it should NEVER be committed).
#   4. When working with Claude in chat, you can say:
#        "my credentials are in .env.local, use placeholders in any commands"
#      Claude will reference these names ($JIRA_TOKEN etc.) without ever seeing
#      the actual values. You substitute them at execution time on your machine.
#
# ROTATION:
#   If you suspect any credential has been exposed (pasted into chat, leaked in
#   a screenshot, committed to git by mistake), rotate it immediately at the
#   source service and update this file.
#
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════
# JIRA — Syndeo test instance
# ═══════════════════════════════════════════════════════════════════════════
# Used for curl-based Jira API calls (MCP connector covers xtm-cloud only).
# Token generated at: https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_SYNDEO_DOMAIN=syndeo-test.atlassian.net
JIRA_SYNDEO_EMAIL=andy@syndeo.cz
JIRA_SYNDEO_TOKEN=

# Example curl pattern (Claude will build these using the variables above):
# curl -u "$JIRA_SYNDEO_EMAIL:$JIRA_SYNDEO_TOKEN" \
#   "https://$JIRA_SYNDEO_DOMAIN/rest/api/3/issue/WT-1"


# ═══════════════════════════════════════════════════════════════════════════
# JIRA — XTM Cloud instance (covered by Atlassian MCP connector)
# ═══════════════════════════════════════════════════════════════════════════
# Typically accessed through MCP rather than direct API, but capture the
# context here in case curl is needed.

JIRA_XTM_DOMAIN=xtm-cloud.atlassian.net
JIRA_XTM_EMAIL=
JIRA_XTM_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE — WindTribe project (Frankfurt region)
# ═══════════════════════════════════════════════════════════════════════════
# Project URL and keys from Supabase dashboard → Project Settings → API
# The anon key is safe for client-side use (protected by RLS).
# The service_role key bypasses RLS — SERVER-SIDE ONLY, NEVER ship to browser.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local Supabase CLI (if using `supabase start`)
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_ANON_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# VERCEL — deployment
# ═══════════════════════════════════════════════════════════════════════════
# Most deployment work happens through Vercel CLI or dashboard.
# Token only needed for programmatic deployment or CI scripting.

VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID_GUEST=
VERCEL_PROJECT_ID_CENTRE_ADMIN=
VERCEL_PROJECT_ID_HOTEL_ADMIN=


# ═══════════════════════════════════════════════════════════════════════════
# GITHUB — repository and CI
# ═══════════════════════════════════════════════════════════════════════════
# Personal access token with `repo` scope for scripting, or fine-grained
# token scoped to the WindTribe repository only.

GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=


# ═══════════════════════════════════════════════════════════════════════════
# STRIPE — payments (when Phase 1 payment work begins)
# ═══════════════════════════════════════════════════════════════════════════
# Test keys during development, live keys only in production environment.
# Use test keys in .env.local — NEVER put live keys in a local file.

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=


# ═══════════════════════════════════════════════════════════════════════════
# WEATHER & CONDITIONS DATA
# ═══════════════════════════════════════════════════════════════════════════
# Open-Meteo is free and requires no key.
# StormGlass requires an API key; only populate when moving beyond free tier.

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
STORMGLASS_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# MAPS
# ═══════════════════════════════════════════════════════════════════════════
# Mapbox access token for destination pages and admin maps.

MAPBOX_ACCESS_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════
# EMAIL — transactional sending (Slice G)
# ═══════════════════════════════════════════════════════════════════════════
# Resend for booking confirmations. While RESEND_API_KEY is empty, the email
# module short-circuits and console-logs the would-be send — the booking
# flow still works, guests just don't receive an email yet.
#
# EMAIL_FROM_ADDRESS: until you verify a domain in Resend, leave blank and
# sends go from onboarding@resend.dev (Resend default, delivers only to the
# account owner). Once windtribe.com (or similar) is verified, set to
# e.g. "WindTribe <hello@windtribe.com>".
#
# INTERNAL_BOOKING_NOTIFICATIONS_EMAIL (optional): BCC every booking email
# to this address so the WindTribe inbox sees new bookings without needing
# to poll Supabase.

EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=
RESEND_API_KEY=
INTERNAL_BOOKING_NOTIFICATIONS_EMAIL=


# ═══════════════════════════════════════════════════════════════════════════
# ION OPERATIONAL PLATFORM — integration
# ═══════════════════════════════════════════════════════════════════════════
# Endpoint and token for writing WindTribe bookings into the ION operational
# system. Established during Epic 9.

ION_PLATFORM_API_URL=
ION_PLATFORM_API_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════

SENTRY_DSN_GUEST=
SENTRY_DSN_CENTRE_ADMIN=
SENTRY_DSN_HOTEL_ADMIN=
SENTRY_AUTH_TOKEN=

PLAUSIBLE_DOMAIN=
# or POSTHOG_API_KEY= if using PostHog instead


# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT FLAGS
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:3000
LOG_LEVEL=debug


# ═══════════════════════════════════════════════════════════════════════════
# ACTIVITY FEED — Facebook Page Plugin (Slice K)
# ═══════════════════════════════════════════════════════════════════════════
# Public Facebook Page URL whose timeline appears on /journal. The site
# embeds it via FB's own Page Plugin iframe — no API key, no auth, no
# scraping. Leave empty and /journal renders a "Feed coming soon" message.

NUXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/ion.club.karpathos


# ═══════════════════════════════════════════════════════════════════════════
# NOTES FOR CLAUDE SESSIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# When you share this file context with Claude in a future session, Claude
# will know:
#
#   • Which credentials exist and what they're for
#   • Which variable names to reference in scripts and curl commands
#   • Never to ask for or echo back the actual values
#
# Claude will build commands like:
#
#   curl -u "$JIRA_SYNDEO_EMAIL:$JIRA_SYNDEO_TOKEN" \
#     "https://$JIRA_SYNDEO_DOMAIN/rest/api/3/search?jql=project=WT"
#
# and you substitute values at execution time locally. The actual tokens
# stay in this file on your machine and never pass through a chat transcript.
#
# ═══════════════════════════════════════════════════════════════════════════
